# ─────────────────────────────────────
# 개발 환경 사용법
#   cp .env.example .env.dev  →  docker compose up
# ─────────────────────────────────────

# Django
DEBUG=1
SECRET_KEY=
ALLOWED_HOSTS=localhost 127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_ENV=local

# Database
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=aramtax
SQL_USER=aramtax
SQL_PASSWORD=aramtaxpassword
SQL_HOST=db         # Docker: db (서비스명) | 네이티브: localhost
SQL_PORT=5432
DATABASE=postgres   # postgres 이면 entrypoint.sh에서 대기 로직 실행

# Email (개발 환경: 콘솔 출력으로 대체 가능 — local.py에서 console backend 설정)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
ADMIN_EMAIL=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
BACKUP_S3_BUCKET=
